generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////////

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())

  // Dados pertencentes ao utilizador
  printers       Printer[]
  filamentTypes  FilamentType[]
  filamentSpools FilamentSpool[]
  categories     Category[]
  extras         Extra[]
  products       Product[]
  productionLogs ProductionLog[]
  sales          Sale[]
  printProfiles  PrintProfile[]
  settings       Settings[]
  spoolAdjustments SpoolAdjustment[]
}

//////////////////////////////////////////////////////////
// FILAMENT TYPES
//////////////////////////////////////////////////////////

model FilamentType {
  id        String   @id @default(cuid())
  userId    String
  brand     String
  material  String
  colorName String
  colorHex  String
  createdAt DateTime @default(now())

  user   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  spools FilamentSpool[]
  usages ProductFilamentUsage[]
}

//////////////////////////////////////////////////////////
// FILAMENT SPOOLS
//////////////////////////////////////////////////////////

model FilamentSpool {
  id             String   @id @default(cuid())
  userId         String                          // ✅ adicionado para isolamento direto
  filamentTypeId String
  spoolWeight    Float
  remaining      Float
  price          Float
  purchaseDate   DateTime
  createdAt      DateTime @default(now())

  adjustments SpoolAdjustment[]
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  filamentType FilamentType @relation(fields: [filamentTypeId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////////
// AJUSTES DE FILAMENTO (para controlar desperdício e correções)
//////////////////////////////////////////////////////////
model SpoolAdjustment {
  id        String   @id @default(cuid())
  userId    String
  spoolId   String
  amount    Float    // negativo = desperdício, positivo = correção
  reason    String?
  createdAt DateTime @default(now())

  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  spool FilamentSpool @relation(fields: [spoolId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////////
// PRINTERS
//////////////////////////////////////////////////////////

model Printer {
  id         String  @id @default(cuid())
  userId     String
  presetId   String?                        // ← adicionar
  name       String
  hourlyCost Float
  powerWatts Int

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  preset  PrinterPreset? @relation(fields: [presetId], references: [id])  // ← adicionar
  products    Product[]
  productions ProductionLog[]
}

//////////////////////////////////////////////////////////
// CATEGORIES
//////////////////////////////////////////////////////////

model Category {
  id     String @id @default(cuid())
  userId String
  name   String
  description String?  // ← adicionar

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
}

//////////////////////////////////////////////////////////
// PRODUCTS
//////////////////////////////////////////////////////////

model Product {
  id             String   @id @default(cuid())
  userId         String
  name           String
  description    String?
  categoryId     String?
  productionTime Int?
  margin         Float    @default(0.3)
  imageUrl       String?
  fileUrl        String?
  printerId      String?                         // ✅ opcional — impressora escolhida na produção
  unitsPerPrint  Int  @default(1)   // ← adicionar
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  printer        Printer?               @relation(fields: [printerId], references: [id])
  category       Category?              @relation(fields: [categoryId], references: [id])
  filamentUsage  ProductFilamentUsage[]
  extras         ProductExtra[]
  printProfiles  PrintProfile[]
  productionLogs ProductionLog[]
  sales          Sale[]
}

//////////////////////////////////////////////////////////
// FILAMENT USED BY PRODUCT
//////////////////////////////////////////////////////////

model ProductFilamentUsage {
  id             String @id @default(cuid())
  productId      String
  filamentTypeId String
  weight         Float

  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  filamentType FilamentType @relation(fields: [filamentTypeId], references: [id])
}

//////////////////////////////////////////////////////////
// EXTRAS
//////////////////////////////////////////////////////////

model Extra {
  id          String  @id @default(cuid())
  userId      String
  name        String
  description String?   // ← adicionar
  price       Float
  unit        String?

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages ProductExtra[]
}

//////////////////////////////////////////////////////////
// EXTRAS USED IN PRODUCT
//////////////////////////////////////////////////////////

model ProductExtra {
  id        String @id @default(cuid())
  productId String
  extraId   String
  quantity  Float

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  extra   Extra   @relation(fields: [extraId], references: [id])
}

//////////////////////////////////////////////////////////
// PRINT PROFILES
//////////////////////////////////////////////////////////

model PrintProfile {
  id           String   @id @default(cuid())
  userId       String                            // ✅ adicionado para isolamento direto
  productId    String
  name         String
  filePath     String
  slicer       String?
  printTime    Int?
  filamentUsed Float?
  createdAt    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////////
// PRINTER PRESETS (para guardar configurações de impressoras sem criar uma impressora real)
//////////////////////////////////////////////////////////

model PrinterPreset {
  id         String   @id @default(cuid())
  name       String
  powerWatts Int
  hourlyCost Float
  imageUrl   String?
  createdAt  DateTime @default(now())

  printers Printer[]
}

//////////////////////////////////////////////////////////
// PRODUCTION LOG
//////////////////////////////////////////////////////////

model ProductionLog {
  id              String   @id @default(cuid())
  userId          String
  productId       String
  printerId       String
  quantity        Int
  notes           String?
  filamentCost    Float?
  electricityCost Float?
  printerCost     Float?
  extrasCost      Float?
  totalCost       Float?
  printTime       Int?    // ← adicionar se não existir
  filamentUsed    Float?  // ← adicionar se não existir
  date            DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  printer Printer @relation(fields: [printerId], references: [id])
}

//////////////////////////////////////////////////////////
// SALES
//////////////////////////////////////////////////////////

model Sale {
  id           String   @id @default(cuid())
  userId       String
  productId    String
  customerName String?
  quantity     Int
  salePrice    Float
  date         DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

//////////////////////////////////////////////////////////
// SETTINGS (por utilizador)
//////////////////////////////////////////////////////////

model Settings {
  id     String @id @default(cuid())
  userId String
  key    String
  value  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}
