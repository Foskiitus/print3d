generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////////

model User {
  id               String  @id
  email            String  @unique
  name             String?
  password         String?
  role             String  @default("user")
  stripeCustomerId String?
  plan             String  @default("hobby")

  subscription     Subscription?
  createdAt        DateTime @default(now())

  customers         Customer[]
  suppliers         Supplier[]
  inventoryItems    InventoryItem[]
  purchases         InventoryPurchase[]
  printers          Printer[]
  printerPresets    PrinterPreset[]
  categories        Category[]
  extras            Extra[]
  products          Product[]
  components        Component[]         // peças reutilizáveis
  productionOrders  ProductionOrder[]   // ordens de produção
  printJobs         PrintJob[]
  sales             Sale[]
  printProfiles     PrintProfile[]
  settings          Settings[]
}

//////////////////////////////////////////////////////////
// SUPPLIERS
//////////////////////////////////////////////////////////

model Supplier {
  id        String   @id @default(cuid())
  userId    String
  name      String
  url       String?
  notes     String?
  createdAt DateTime @default(now())

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchases InventoryPurchase[]

  @@index([userId])
}

//////////////////////////////////////////////////////////
// INVENTORY ITEMS
//////////////////////////////////////////////////////////

model InventoryItem {
  id               String   @id @default(cuid())
  userId           String
  brand            String
  material         String
  colorName        String
  colorHex         String   @default("#3b82f6")
  globalFilamentId String?
  alertThreshold   Float?
  createdAt        DateTime @default(now())

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchases InventoryPurchase[]

  @@index([userId])
}

//////////////////////////////////////////////////////////
// INVENTORY PURCHASES (rolos físicos)
//////////////////////////////////////////////////////////

model InventoryPurchase {
  id             String    @id @default(cuid())
  userId         String
  itemId         String
  supplierId     String?
  qrCodeId       String    @unique
  initialWeight  Float
  currentWeight  Float
  tareWeight     Float     @default(0)
  priceCents     Int
  boughtAt       DateTime  @default(now())
  openedAt       DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  archivedAt     DateTime?

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  item              InventoryItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  supplier          Supplier?         @relation(fields: [supplierId], references: [id])
  loadedInSlot      PrinterSlot?
  printJobMaterials PrintJobMaterial[]

  @@index([userId])
  @@index([itemId])
}

//////////////////////////////////////////////////////////
// SUBSCRIPTIONS
//////////////////////////////////////////////////////////

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  stripeSubscriptionId String   @unique
  stripePriceId        String
  status               String
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////////
// PRINTERS
//////////////////////////////////////////////////////////

model Printer {
  id                String    @id @default(cuid())
  userId            String
  presetId          String
  name              String
  qrCodeId          String    @unique

  totalPrintTime    Int       @default(0)
  initialHours      Int       @default(0)
  lastMaintenanceAt Int       @default(0)

  hourlyCost        Float
  powerWatts        Int

  acquiredAt        DateTime?
  status            String    @default("idle")

  apiType           String?   // "octoprint" | "moonraker" | "bambu"
  apiUrl            String?
  apiKey            String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  preset           PrinterPreset   @relation(fields: [presetId], references: [id])
  units            PrinterUnit[]
  printJobs        PrintJob[]
  maintenanceLogs  MaintenanceLog[]

  @@index([userId])
  @@index([qrCodeId])
}

//////////////////////////////////////////////////////////
// PRINTER UNITS
//////////////////////////////////////////////////////////

model PrinterUnit {
  id               String   @id @default(cuid())
  printerId        String
  presetId         String?
  name             String
  slotCount        Int
  supportsHighTemp Boolean  @default(false)
  supportsAbrasive Boolean  @default(false)
  createdAt        DateTime @default(now())

  printer    Printer       @relation(fields: [printerId], references: [id], onDelete: Cascade)
  unitPreset UnitPreset?   @relation(fields: [presetId], references: [id])
  slots      PrinterSlot[]

  @@index([printerId])
}

//////////////////////////////////////////////////////////
// PRINTER SLOTS
//////////////////////////////////////////////////////////

model PrinterSlot {
  id             String    @id @default(cuid())
  unitId         String
  position       Int
  currentSpoolId String?   @unique
  loadedAt       DateTime?

  unit         PrinterUnit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  currentSpool InventoryPurchase? @relation(fields: [currentSpoolId], references: [id], onDelete: SetNull)

  @@unique([unitId, position])
  @@index([unitId])
}

//////////////////////////////////////////////////////////
// UNIT PRESETS
//////////////////////////////////////////////////////////

model UnitPreset {
  id               String   @id @default(cuid())
  name             String
  brand            String
  slotCount        Int
  supportsHighTemp Boolean  @default(false)
  supportsAbrasive Boolean  @default(false)
  notes            String?
  isGlobal         Boolean  @default(true)
  createdAt        DateTime @default(now())

  units PrinterUnit[]

  @@index([brand])
}

//////////////////////////////////////////////////////////
// PRINTER PRESETS
//////////////////////////////////////////////////////////

model PrinterPreset {
  id                 String   @id @default(cuid())
  name               String
  brand              String?
  model              String?
  extrusionType      String?
  multiMaterialSlots Int      @default(1)
  powerWatts         Int
  hourlyCost         Float
  imageUrl           String?
  isGlobal           Boolean  @default(false)
  userId             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user             User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  printers         Printer[]
  maintenanceTasks MaintenanceTask[]
}

//////////////////////////////////////////////////////////
// MAINTENANCE TASKS / LOGS
//////////////////////////////////////////////////////////

model MaintenanceTask {
  id            String        @id @default(cuid())
  presetId      String
  taskName      String
  intervalHours Int
  description   String?

  preset PrinterPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)
}

model MaintenanceLog {
  id               String   @id @default(cuid())
  printerId        String
  taskName         String
  performedAtHours Int
  notes            String?
  createdAt        DateTime @default(now())

  printer Printer @relation(fields: [printerId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////////
// CATEGORIES
//////////////////////////////////////////////////////////

model Category {
  id          String @id @default(cuid())
  userId      String
  name        String
  description String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
}

//////////////////////////////////////////////////////////
// PRODUCTS (o que vendes — produto final)
//////////////////////////////////////////////////////////

model Product {
  id             String   @id @default(cuid())
  userId         String
  name           String
  description    String?
  categoryId     String?
  margin         Float    @default(0.3)
  imageUrl       String?
  imageKey       String?
  alertThreshold Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category?      @relation(fields: [categoryId], references: [id])
  extras     ProductExtra[]
  bom        ProductBOM[]   // lista de materiais (componentes)
  orderItems OrderItem[]
  sales      Sale[]
}

//////////////////////////////////////////////////////////
// COMPONENTS (peças reutilizáveis — semiacabados)
//
// Uma Component é uma peça física que pode ser usada em vários produtos.
// Ex: "Base Redonda 10cm" usada em "Candeeiro A" e "Candeeiro B".
//////////////////////////////////////////////////////////

model Component {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  imageUrl    String?
  imageKey    String?

  // Flags de risco — lidas pelo Planeador para gerar avisos
  requiresAdapter   Boolean  @default(false) // bobine não-standard, precisa de adaptador físico
  specialHandling   String?  // nota livre: ex: "TPU — desligar o AMS retractor"
  defaultMaterial   String?  // ex: "PLA", "PETG" — para sugestão no planeador
  defaultColorHex   String?  // ex: "#000000"

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  bom          ProductBOM[]
  profiles     ComponentPrintProfile[]
  stock        ComponentStock?         // stock de unidades impressas (1:1)
  jobItems     PrintJobItem[]

  @@index([userId])
}

//////////////////////////////////////////////////////////
// PRODUCT BOM (Bill of Materials — tabela many-to-many)
//
// Liga Produtos a Componentes com quantidade.
// Ex: "Estátua XPTO" = 1x Cabeça + 1x Corpo + 1x Base
//////////////////////////////////////////////////////////

model ProductBOM {
  id          String @id @default(cuid())
  productId   String
  componentId String
  quantity    Int    @default(1)   // quantas unidades deste componente por produto

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  component Component @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@unique([productId, componentId])
  @@index([productId])
  @@index([componentId])
}

//////////////////////////////////////////////////////////
// COMPONENT PRINT PROFILES
//
// Cada componente pode ter um ou mais perfis de impressão (.3mf).
// Ex: "Base Redonda 10cm" tem perfis para PLA Preto e PLA Branco.
//////////////////////////////////////////////////////////

model ComponentPrintProfile {
  id           String   @id @default(cuid())
  componentId  String
  name         String                          // ex: "Vaso Single", "Vaso Multi-9"
  filePath     String
  slicer       String?
  printTime    Int?                            // minutos para imprimir este lote
  filamentUsed Float?                          // gramas totais para este lote

  // Receita de produção — quantas unidades saem desta impressão
  // batchSize=1 → individual; batchSize=9 → lote de 9
  // Custo unitário real = filamentUsed / batchSize
  batchSize    Int      @default(1)

  createdAt    DateTime @default(now())

  component    Component              @relation(fields: [componentId], references: [id], onDelete: Cascade)
  filaments    ProfileFilamentReq[]
  jobItems     PrintJobItem[]

  @@index([componentId])
}

//////////////////////////////////////////////////////////
// PROFILE FILAMENT REQUIREMENTS
//
// Os filamentos exigidos por um perfil de impressão.
// Extraídos do .3mf ou inseridos manualmente.
// Ex: "Base v2 - PLA Preto" precisa de 30g de PLA #000000
//////////////////////////////////////////////////////////

model ProfileFilamentReq {
  id          String  @id @default(cuid())
  profileId   String
  material    String                  // ex: "PLA"
  colorHex    String?                 // ex: "#000000"
  colorName   String?                 // ex: "Black"
  estimatedG  Float                   // gramas estimadas

  profile ComponentPrintProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

//////////////////////////////////////////////////////////
// COMPONENT STOCK
//
// Stock de unidades de componente já impressas (semiacabados).
// Ex: 20 unidades de "Base Redonda 10cm" em prateleira.
//////////////////////////////////////////////////////////

model ComponentStock {
  id          String   @id @default(cuid())
  componentId String
  quantity    Int      @default(0)
  notes       String?
  updatedAt   DateTime @updatedAt

  component Component @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@unique([componentId])  // um registo por componente
}

//////////////////////////////////////////////////////////
// EXTRAS
//////////////////////////////////////////////////////////

model Extra {
  id          String  @id @default(cuid())
  userId      String
  name        String
  description String?
  price       Float
  unit        String?

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages ProductExtra[]
}

model ProductExtra {
  id        String @id @default(cuid())
  productId String
  extraId   String
  quantity  Float

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  extra   Extra   @relation(fields: [extraId], references: [id])
}

//////////////////////////////////////////////////////////
// PRODUCTION ORDER (Ordem de Produção)
//
// Contentor de necessidades que agrega vários produtos.
// A OP "explode" nos PrintJobs necessários para cada componente.
//////////////////////////////////////////////////////////

model ProductionOrder {
  id         String   @id @default(cuid())
  userId     String
  reference  String                    // ex: "OP-2026-001" (gerado auto ou manual)
  notes      String?
  status     String   @default("draft")
  // "draft"      → em criação
  // "pending"    → aguarda impressão
  // "in_progress"→ impressão a decorrer
  // "assembly"   → peças prontas, a aguardar montagem
  // "done"       → produto final pronto para stock
  // "cancelled"

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     OrderItem[] // produtos e quantidades nesta ordem
  printJobs PrintJob[]  // trabalhos de impressão gerados

  @@index([userId])
  @@index([status])
}

//////////////////////////////////////////////////////////
// ORDER ITEM
//
// Um produto (e quantidade) dentro de uma Ordem de Produção.
// Ex: 3x "Estátua XPTO" + 2x "Porta-chaves"
//////////////////////////////////////////////////////////

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int

  // Estado de conclusão (quantas unidades deste produto já estão prontas)
  completed Int    @default(0)

  order   ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])

  @@index([orderId])
}

//////////////////////////////////////////////////////////
// PRINT JOB (Trabalho de Impressão)
//
// Um único trabalho de impressão para um componente específico.
// Gerado pela explosão da Ordem de Produção.
// Pode ser para qualquer impressora disponível.
//////////////////////////////////////////////////////////

model PrintJob {
  id        String   @id @default(cuid())
  userId    String
  orderId   String?                     // OP de origem (null = job avulso)
  printerId String
  status    String   @default("pending")
  // "pending"   → na fila
  // "printing"  → a imprimir agora
  // "done"      → concluído com sucesso
  // "failed"    → falhou (vai para re-fila)
  // "cancelled"

  // Metadados
  notes            String?
  estimatedMinutes Int?
  quantity         Int      @default(1)   // quantas unidades deste job

  // Custos calculados no dispatch
  filamentCost     Float?
  electricityCost  Float?
  printerCost      Float?
  totalCost        Float?

  // Integração externa
  externalJobId    String?
  apiDispatched    Boolean  @default(false)

  startedAt        DateTime?
  finishedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     ProductionOrder? @relation(fields: [orderId], references: [id])
  printer   Printer          @relation(fields: [printerId], references: [id])
  items     PrintJobItem[]   // componentes a imprimir neste job
  materials PrintJobMaterial[] // rolos e slots usados

  @@index([userId])
  @@index([orderId])
  @@index([printerId])
  @@index([status])
}

//////////////////////////////////////////////////////////
// PRINT JOB ITEM
//
// Um componente dentro de um PrintJob.
// Um job pode imprimir vários componentes na mesma bandeja.
// Ex: "Mesa 1 (Corpo)" + "Mesa 1 (Base)" na mesma impressão.
//////////////////////////////////////////////////////////

model PrintJobItem {
  id          String  @id @default(cuid())
  jobId       String
  componentId String
  profileId   String?  // perfil .3mf específico usado
  quantity    Int      @default(1)

  // Resultado
  status      String   @default("pending")
  // "pending" | "done" | "failed"
  failedUnits Int      @default(0)     // quantas falharam neste item

  // Para rateio de custos entre componentes do mesmo job
  costShare   Float?   // % do custo total imputado a este componente

  job       PrintJob               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  component Component              @relation(fields: [componentId], references: [id])
  profile   ComponentPrintProfile? @relation(fields: [profileId], references: [id])

  @@index([jobId])
  @@index([componentId])
}

//////////////////////////////////////////////////////////
// PRINT JOB MATERIAL
//
// Liga cada requisito de filamento ao slot e rolo usados.
// Permite rateio: se 2 componentes partilham a mesma impressão,
// o custo do filamento é dividido proporcionalmente.
//////////////////////////////////////////////////////////

model PrintJobMaterial {
  id         String  @id @default(cuid())
  jobId      String
  slotId     String?
  spoolId    String?

  material   String          // ex: "PLA"
  colorHex   String?
  colorName  String?
  estimatedG Float
  actualG    Float?          // preenchido no fim da impressão
  matchScore Int    @default(100)

  job   PrintJob           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  spool InventoryPurchase? @relation(fields: [spoolId], references: [id])

  @@index([jobId])
}

//////////////////////////////////////////////////////////
// GLOBAL FILAMENTS
//////////////////////////////////////////////////////////

model GlobalFilament {
  id          String   @id @default(cuid())
  brand       String
  material    String
  colorName   String
  colorCode   String?  // ex: "11101" — código numérico/alfanumérico da cor
  colorHex    String
  spoolWeight Float
  density     Float?
  createdAt   DateTime @default(now())

  @@index([brand])
  @@index([material])
  @@index([colorCode])
}

//////////////////////////////////////////////////////////
// SALES
//////////////////////////////////////////////////////////

model Sale {
  id           String   @id @default(cuid())
  userId       String
  productId    String
  customerName String?
  quantity     Int
  salePrice    Float
  notes        String?
  date         DateTime @default(now())
  customerId   String?

  customer Customer? @relation(fields: [customerId], references: [id])
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product  Product   @relation(fields: [productId], references: [id])
}

//////////////////////////////////////////////////////////
// CUSTOMERS
//////////////////////////////////////////////////////////

model Customer {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String?
  phone     String?
  address   String?
  nif       String?
  notes     String?
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales Sale[]
}

//////////////////////////////////////////////////////////
// SETTINGS
//////////////////////////////////////////////////////////

model Settings {
  id     String @id @default(cuid())
  userId String
  key    String
  value  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

//////////////////////////////////////////////////////////
// PRINT PROFILES (legado — mantido para compatibilidade)
// Para novos componentes usa ComponentPrintProfile
//////////////////////////////////////////////////////////

model PrintProfile {
  id           String   @id @default(cuid())
  userId       String
  name         String
  filePath     String
  slicer       String?
  printTime    Int?
  filamentUsed Float?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
