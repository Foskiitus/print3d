generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

//////////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////////

model User {
  id       String  @id
  email    String  @unique
  name     String?
  password String?
  role     String  @default("user")
  stripeCustomerId     String?
  plan                 String  @default("hobby")
  subscription         Subscription?

  createdAt DateTime @default(now())

  customers      Customer[]
  suppliers      Supplier[]
  inventoryItems InventoryItem[]
  purchases      InventoryPurchase[]
  printers       Printer[]
  categories     Category[]
  extras         Extra[]
  products       Product[]
  productionLogs ProductionLog[]
  sales          Sale[]
  printProfiles  PrintProfile[]
  settings       Settings[]
  printerPresets PrinterPreset[]   // presets privados do utilizador
}

//////////////////////////////////////////////////////////
// SUPPLIERS
//////////////////////////////////////////////////////////

model Supplier {
  id        String   @id @default(cuid())
  userId    String
  name      String
  url       String?
  notes     String?
  createdAt DateTime @default(now())

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchases InventoryPurchase[]

  @@index([userId])
}

//////////////////////////////////////////////////////////
// INVENTORY ITEMS
//////////////////////////////////////////////////////////

model InventoryItem {
  id               String   @id @default(cuid())
  userId           String
  brand            String
  material         String
  colorName        String
  colorHex         String   @default("#3b82f6")
  globalFilamentId String?
  alertThreshold   Float?
  createdAt        DateTime @default(now())

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchases InventoryPurchase[]

  @@index([userId])
}

//////////////////////////////////////////////////////////
// INVENTORY PURCHASES (rolos físicos)
//////////////////////////////////////////////////////////

model InventoryPurchase {
  id             String    @id @default(cuid())
  userId         String
  itemId         String
  supplierId     String?
  qrCodeId       String    @unique
  initialWeight  Float
  currentWeight  Float
  tareWeight     Float     @default(0)
  priceCents     Int
  boughtAt       DateTime  @default(now())
  openedAt       DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  archivedAt     DateTime?

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  item     InventoryItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  supplier Supplier?      @relation(fields: [supplierId], references: [id])

  // Um rolo pode estar carregado em vários slots? Não — relação 1:1 via PrinterSlot
  loadedInSlot  PrinterSlot?

  @@index([userId])
  @@index([itemId])
}

//////////////////////////////////////////////////////////
// SUBSCRIPTIONS
//////////////////////////////////////////////////////////

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  stripeSubscriptionId String   @unique
  stripePriceId        String
  status               String
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////////
// PRINTERS
//////////////////////////////////////////////////////////

model Printer {
  id                String    @id @default(cuid())
  userId            String
  presetId          String
  name              String                      // ex: "Besta de Carga 01"
  qrCodeId          String    @unique           // ID para check-in QR/NFC

  // Métricas de uso acumulado
  totalPrintTime    Int       @default(0)       // minutos totais impressos
  initialHours      Int       @default(0)       // horas já feitas ao registar
  lastMaintenanceAt Int       @default(0)       // horas na última revisão geral

  // Custos operacionais da instância
  hourlyCost        Float
  powerWatts        Int

  // Metadados de aquisição
  acquiredAt        DateTime?
  status            String    @default("idle")  // "idle" | "printing" | "maintenance"

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  preset           PrinterPreset      @relation(fields: [presetId], references: [id])
  units            PrinterUnit[]      // unidades de expansão (AMS, MMU, ERCF…)
  productions      ProductionLog[]
  maintenanceLogs  MaintenanceLog[]

  @@index([userId])
  @@index([qrCodeId])
}

//////////////////////////////////////////////////////////
// PRINTER UNITS
// Cada registo é uma unidade física ligada à impressora.
// ex: AMS 2 Pro (4 slots), AMS HT (1 slot), MMU3 (5 slots)
//////////////////////////////////////////////////////////

model PrinterUnit {
  id          String   @id @default(cuid())
  printerId   String
  presetId    String?                       // referência ao UnitPreset (opcional)
  name        String                        // ex: "AMS 2 Pro", "MMU3"
  slotCount   Int                           // número de posições físicas

  // Capacidades do hardware desta unidade
  supportsHighTemp  Boolean @default(false) // aceita PA, PC, ABS acima de 300°C
  supportsAbrasive  Boolean @default(false) // aceita CF, GF, etc.

  createdAt   DateTime @default(now())

  printer     Printer       @relation(fields: [printerId], references: [id], onDelete: Cascade)
  unitPreset  UnitPreset?   @relation(fields: [presetId], references: [id])
  slots       PrinterSlot[]

  @@index([printerId])
}

//////////////////////////////////////////////////////////
// PRINTER SLOTS
// Gerados automaticamente ao criar uma PrinterUnit.
// Cada slot é uma posição física (posição 1, 2, 3, 4…).
//////////////////////////////////////////////////////////

model PrinterSlot {
  id             String   @id @default(cuid())
  unitId         String
  position       Int                           // 1-based (posição 1, 2, 3…)
  currentSpoolId String?  @unique              // rolo carregado (nullable)
  loadedAt       DateTime?                     // quando foi carregado

  unit         PrinterUnit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  currentSpool InventoryPurchase? @relation(fields: [currentSpoolId], references: [id], onDelete: SetNull)

  @@unique([unitId, position])
  @@index([unitId])
}

//////////////////////////////////////////////////////////
// UNIT PRESETS
// Catálogo global de unidades de expansão.
// ex: AMS 2 Pro, AMS HT, MMU3, ERCF 8T, ERCF 12T
//////////////////////////////////////////////////////////

model UnitPreset {
  id                String   @id @default(cuid())
  name              String                        // ex: "AMS 2 Pro"
  brand             String                        // ex: "Bambu Lab"
  slotCount         Int                           // posições físicas
  supportsHighTemp  Boolean  @default(false)
  supportsAbrasive  Boolean  @default(false)
  notes             String?                       // info adicional opcional
  isGlobal          Boolean  @default(true)       // false = privado do utilizador

  createdAt         DateTime @default(now())

  units             PrinterUnit[]

  @@index([brand])
}

//////////////////////////////////////////////////////////
// PRINTER PRESETS
// isGlobal = true  → criado por admin, visível a todos
// isGlobal = false → criado pelo utilizador, privado
//////////////////////////////////////////////////////////

model PrinterPreset {
  id                 String   @id @default(cuid())
  name               String
  brand              String?
  model              String?
  extrusionType      String?                       // "Direct" | "Bowden"
  multiMaterialSlots Int      @default(1)          // máximo suportado pelo fabricante
  powerWatts         Int
  hourlyCost         Float
  imageUrl           String?
  isGlobal           Boolean  @default(false)
  userId             String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user              User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  printers          Printer[]
  maintenanceTasks  MaintenanceTask[]
}

//////////////////////////////////////////////////////////
// MAINTENANCE TASKS (definidas no PrinterPreset)
//////////////////////////////////////////////////////////

model MaintenanceTask {
  id            String        @id @default(cuid())
  presetId      String
  taskName      String
  intervalHours Int
  description   String?

  preset        PrinterPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////////
// MAINTENANCE LOG (histórico de manutenções realizadas)
//////////////////////////////////////////////////////////

model MaintenanceLog {
  id               String   @id @default(cuid())
  printerId        String
  taskName         String
  performedAtHours Int
  notes            String?
  createdAt        DateTime @default(now())

  printer          Printer  @relation(fields: [printerId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////////
// CATEGORIES
//////////////////////////////////////////////////////////

model Category {
  id          String @id @default(cuid())
  userId      String
  name        String
  description String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
}

//////////////////////////////////////////////////////////
// PRODUCTS
//////////////////////////////////////////////////////////

model Product {
  id             String   @id @default(cuid())
  userId         String
  name           String
  description    String?
  categoryId     String?
  productionTime Int?
  margin         Float    @default(0.3)
  imageUrl       String?
  fileUrl        String?
  imageKey       String?
  fileKey        String?
  unitsPerPrint  Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  alertThreshold Int?

  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  category       Category?              @relation(fields: [categoryId], references: [id])
  extras         ProductExtra[]
  printProfiles  PrintProfile[]
  productionLogs ProductionLog[]
  sales          Sale[]
}

//////////////////////////////////////////////////////////
// EXTRAS
//////////////////////////////////////////////////////////

model Extra {
  id          String  @id @default(cuid())
  userId      String
  name        String
  description String?
  price       Float
  unit        String?

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages ProductExtra[]
}

//////////////////////////////////////////////////////////
// EXTRAS USED IN PRODUCT
//////////////////////////////////////////////////////////

model ProductExtra {
  id        String @id @default(cuid())
  productId String
  extraId   String
  quantity  Float

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  extra   Extra   @relation(fields: [extraId], references: [id])
}

//////////////////////////////////////////////////////////
// PRINT PROFILES
//////////////////////////////////////////////////////////

model PrintProfile {
  id           String   @id @default(cuid())
  userId       String
  productId    String
  name         String
  filePath     String
  slicer       String?
  printTime    Int?
  filamentUsed Float?
  createdAt    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////////
// GLOBAL FILAMENTS
//////////////////////////////////////////////////////////

model GlobalFilament {
  id          String   @id @default(cuid())
  brand       String
  material    String
  colorName   String
  colorHex    String
  spoolWeight Float
  density     Float?
  createdAt   DateTime @default(now())

  @@index([brand])
  @@index([material])
}

//////////////////////////////////////////////////////////
// PRODUCTION LOG
//////////////////////////////////////////////////////////

model ProductionLog {
  id              String   @id @default(cuid())
  userId          String
  productId       String
  printerId       String
  quantity        Int
  notes           String?
  filamentCost    Float?
  electricityCost Float?
  printerCost     Float?
  extrasCost      Float?
  totalCost       Float?
  printTime       Int?
  filamentUsed    Float?
  date            DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  printer Printer @relation(fields: [printerId], references: [id])
}

//////////////////////////////////////////////////////////
// SALES
//////////////////////////////////////////////////////////

model Sale {
  id           String   @id @default(cuid())
  userId       String
  productId    String
  customerName String?
  quantity     Int
  salePrice    Float
  notes        String?
  date         DateTime @default(now())
  customerId   String?

  customer Customer? @relation(fields: [customerId], references: [id])
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product  Product   @relation(fields: [productId], references: [id])
}

//////////////////////////////////////////////////////////
// CUSTOMERS
//////////////////////////////////////////////////////////

model Customer {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String?
  phone     String?
  address   String?
  nif       String?
  notes     String?
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales Sale[]
}

//////////////////////////////////////////////////////////
// SETTINGS
//////////////////////////////////////////////////////////

model Settings {
  id     String @id @default(cuid())
  userId String
  key    String
  value  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}
