generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////////

model User {
  id               String  @id
  email            String  @unique
  name             String?
  password         String?
  avatar           String?
  role             String  @default("user")
  stripeCustomerId String?
  plan             String  @default("hobby")

  subscription     Subscription?
  createdAt        DateTime @default(now())

  customers         Customer[]
  suppliers         Supplier[]
  inventoryItems    InventoryItem[]
  purchases         InventoryPurchase[]
  printers          Printer[]
  printerPresets    PrinterPreset[]
  categories        Category[]
  extras            Extra[]
  products          Product[]
  components        Component[]
  productionOrders  ProductionOrder[]
  printJobs         PrintJob[]
  sales             Sale[]
  printProfiles     PrintProfile[]
  settings          Settings[]
  productStock      ProductStock[]      // ← novo: stock de produto acabado
}

//////////////////////////////////////////////////////////
// SUPPLIERS
//////////////////////////////////////////////////////////

model Supplier {
  id        String   @id @default(cuid())
  userId    String
  name      String
  url       String?
  notes     String?
  createdAt DateTime @default(now())

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchases InventoryPurchase[]

  @@index([userId])
}

//////////////////////////////////////////////////////////
// INVENTORY ITEMS
//////////////////////////////////////////////////////////

model InventoryItem {
  id               String   @id @default(cuid())
  userId           String
  brand            String
  material         String
  colorName        String
  colorCode        String?
  colorHex         String   @default("#3b82f6")
  globalFilamentId String?
  alertThreshold   Float?
  createdAt        DateTime @default(now())

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchases InventoryPurchase[]

  @@index([userId])
}

//////////////////////////////////////////////////////////
// INVENTORY PURCHASES (rolos físicos)
//////////////////////////////////////////////////////////

model InventoryPurchase {
  id             String    @id @default(cuid())
  userId         String
  itemId         String
  supplierId     String?
  qrCodeId       String    @unique
  initialWeight  Float
  currentWeight  Float
  tareWeight     Float     @default(0)
  priceCents     Int
  boughtAt       DateTime  @default(now())
  openedAt       DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  archivedAt     DateTime?

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  item              InventoryItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  supplier          Supplier?         @relation(fields: [supplierId], references: [id])
  loadedInSlot      PrinterSlot?
  printJobMaterials PrintJobMaterial[]

  @@index([userId])
  @@index([itemId])
}

//////////////////////////////////////////////////////////
// SUBSCRIPTIONS
//////////////////////////////////////////////////////////

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  stripeSubscriptionId String   @unique
  stripePriceId        String
  status               String
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////////
// PRINTERS
//////////////////////////////////////////////////////////

model Printer {
  id                String    @id @default(cuid())
  userId            String
  presetId          String
  name              String
  qrCodeId          String    @unique

  totalPrintTime    Int       @default(0)
  initialHours      Int       @default(0)
  lastMaintenanceAt Int       @default(0)

  hourlyCost        Float
  powerWatts        Int

  acquiredAt        DateTime?
  status            String    @default("idle")

  apiType           String?
  apiUrl            String?
  apiKey            String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  preset           PrinterPreset   @relation(fields: [presetId], references: [id])
  units            PrinterUnit[]
  printJobs        PrintJob[]
  maintenanceLogs  MaintenanceLog[]

  @@index([userId])
  @@index([qrCodeId])
}

//////////////////////////////////////////////////////////
// PRINTER UNITS
//////////////////////////////////////////////////////////

model PrinterUnit {
  id               String   @id @default(cuid())
  printerId        String
  presetId         String?
  name             String
  slotCount        Int
  supportsHighTemp Boolean  @default(false)
  supportsAbrasive Boolean  @default(false)
  createdAt        DateTime @default(now())

  printer    Printer       @relation(fields: [printerId], references: [id], onDelete: Cascade)
  unitPreset UnitPreset?   @relation(fields: [presetId], references: [id])
  slots      PrinterSlot[]

  @@index([printerId])
}

//////////////////////////////////////////////////////////
// PRINTER SLOTS
//////////////////////////////////////////////////////////

model PrinterSlot {
  id             String    @id @default(cuid())
  unitId         String
  position       Int
  currentSpoolId String?   @unique
  loadedAt       DateTime?

  unit         PrinterUnit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  currentSpool InventoryPurchase? @relation(fields: [currentSpoolId], references: [id], onDelete: SetNull)

  @@unique([unitId, position])
  @@index([unitId])
}

//////////////////////////////////////////////////////////
// UNIT PRESETS
//////////////////////////////////////////////////////////

model UnitPreset {
  id               String   @id @default(cuid())
  name             String
  brand            String
  slotCount        Int
  supportsHighTemp Boolean  @default(false)
  supportsAbrasive Boolean  @default(false)
  notes            String?
  isGlobal         Boolean  @default(true)
  createdAt        DateTime @default(now())

  units PrinterUnit[]

  @@index([brand])
}

//////////////////////////////////////////////////////////
// PRINTER PRESETS
//////////////////////////////////////////////////////////

model PrinterPreset {
  id                 String   @id @default(cuid())
  name               String
  brand              String?
  model              String?
  extrusionType      String?
  multiMaterialSlots Int      @default(1)
  powerWatts         Int
  hourlyCost         Float
  imageUrl           String?
  isGlobal           Boolean  @default(false)
  userId             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user             User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  printers         Printer[]
  maintenanceTasks MaintenanceTask[]
  componentProfiles ComponentPrintProfile[]
}

//////////////////////////////////////////////////////////
// MAINTENANCE TASKS / LOGS
//////////////////////////////////////////////////////////

model MaintenanceTask {
  id            String        @id @default(cuid())
  presetId      String
  taskName      String
  intervalHours Int
  description   String?

  preset PrinterPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)
}

model MaintenanceLog {
  id               String   @id @default(cuid())
  printerId        String
  taskName         String
  performedAtHours Int
  notes            String?
  createdAt        DateTime @default(now())

  printer Printer @relation(fields: [printerId], references: [id], onDelete: Cascade)
}

//////////////////////////////////////////////////////////
// CATEGORIES
//////////////////////////////////////////////////////////

model Category {
  id          String @id @default(cuid())
  userId      String
  name        String
  description String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
}

//////////////////////////////////////////////////////////
// PRODUCTS
//////////////////////////////////////////////////////////

model Product {
  id             String   @id @default(cuid())
  userId         String
  name           String
  description    String?
  categoryId     String?
  margin         Float    @default(0.3)
  imageUrl       String?
  imageKey       String?
  alertThreshold Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   Category?      @relation(fields: [categoryId], references: [id])
  extras     ProductExtra[]
  bom        ProductBOM[]
  orderItems OrderItem[]
  sales      Sale[]
  stock      ProductStock?  // ← novo: stock de produto acabado (1:1)
}

//////////////////////////////////////////////////////////
// PRODUCT STOCK (Produto Acabado)
//
// Stock de unidades de produto final prontas para venda.
// Incrementado pela conclusão da OP; decrementado pelas vendas.
//////////////////////////////////////////////////////////

model ProductStock {
  id        String   @id @default(cuid())
  userId    String
  productId String   @unique
  quantity  Int      @default(0)
  reserved  Int      @default(0)  // unidades reservadas para vendas pendentes
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([userId])
}

//////////////////////////////////////////////////////////
// COMPONENTS (peças reutilizáveis — semiacabados)
//////////////////////////////////////////////////////////

model Component {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  imageUrl    String?
  imageKey    String?

  requiresAdapter   Boolean  @default(false)
  specialHandling   String?
  defaultMaterial   String?
  defaultColorHex   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  bom          ProductBOM[]
  profiles     ComponentPrintProfile[]
  stock        ComponentStock?
  jobItems     PrintJobItem[]

  @@index([userId])
}

//////////////////////////////////////////////////////////
// PRODUCT BOM (Bill of Materials)
//////////////////////////////////////////////////////////

model ProductBOM {
  id          String @id @default(cuid())
  productId   String
  componentId String
  quantity    Int    @default(1)

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  component Component @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@unique([productId, componentId])
  @@index([productId])
  @@index([componentId])
}

//////////////////////////////////////////////////////////
// COMPONENT PRINT PROFILES
//////////////////////////////////////////////////////////

model ComponentPrintProfile {
  id              String   @id @default(cuid())
  componentId     String
  name            String
  filePath        String
  slicer          String?
  printTime       Int?
  filamentUsed    Float?
  batchSize       Int      @default(1)
  // Modelo de impressora compatível — limita a que impressoras este perfil pode ser enviado.
  // Corresponde a PrinterPreset.model (ex: "P1S", "A1", "X1C").
  // null = compatível com qualquer impressora.
  printerPresetId String?
  createdAt       DateTime @default(now())

  component     Component              @relation(fields: [componentId], references: [id], onDelete: Cascade)
  printerPreset PrinterPreset?         @relation(fields: [printerPresetId], references: [id], onDelete: SetNull)
  filaments     ProfileFilamentReq[]
  jobItems      PrintJobItem[]
  plates        ProfilePlate[]

  @@index([componentId])
  @@index([printerPresetId])
}

//////////////////////////////////////////////////////////
// PROFILE FILAMENT REQUIREMENTS
//////////////////////////////////////////////////////////

model ProfileFilamentReq {
  id          String  @id @default(cuid())
  profileId   String
  material    String
  colorHex    String?
  colorName   String?
  estimatedG  Float

  profile ComponentPrintProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

//////////////////////////////////////////////////////////
// COMPONENT STOCK (semiacabados)
//////////////////////////////////////////////////////////

model ComponentStock {
  id          String   @id @default(cuid())
  componentId String
  quantity    Int      @default(0)
  notes       String?
  updatedAt   DateTime @updatedAt

  component Component @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@unique([componentId])
}

//////////////////////////////////////////////////////////
// EXTRAS
//////////////////////////////////////////////////////////

model Extra {
  id             String  @id @default(cuid())
  userId         String
  name           String
  description    String?
  price          Float
  unit           String?
  category       String? @default("hardware")
  quantity       Float   @default(0)
  alertThreshold Float?

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  usages ProductExtra[]
}

model ProductExtra {
  id        String @id @default(cuid())
  productId String
  extraId   String
  quantity  Float

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  extra   Extra   @relation(fields: [extraId], references: [id])
}

//////////////////////////////////////////////////////////
// PRODUCTION ORDER (Ordem de Produção)
//////////////////////////////////////////////////////////

model ProductionOrder {
  id           String   @id @default(cuid())
  userId       String
  reference    String
  notes        String?
  status       String   @default("draft")
  // "draft"       → em criação
  // "pending"     → aguarda impressão
  // "in_progress" → impressão a decorrer
  // "assembly"    → peças prontas, a aguardar montagem
  // "done"        → produto final creditado no stock
  // "cancelled"

  // ← novo: ligação à venda que originou esta OP (se aplicável)
  salesOrderId String?  @unique

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  salesOrder Sale?       @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  items      OrderItem[]
  printJobs  PrintJob[]

  @@index([userId])
  @@index([status])
  @@index([salesOrderId])
}

//////////////////////////////////////////////////////////
// ORDER ITEM
//////////////////////////////////////////////////////////

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  completed Int    @default(0)

  order   ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])

  @@index([orderId])
}

//////////////////////////////////////////////////////////
// PRINT JOB
//////////////////////////////////////////////////////////

model PrintJob {
  id        String   @id @default(cuid())
  userId    String
  orderId   String?
  printerId String
  status    String   @default("pending")
  plateNumber  Int?                    // ← qual placa este job representa (1-based)
  totalPlates  Int?  
  // "pending" | "printing" | "done" | "failed" | "cancelled"

  notes            String?
  estimatedMinutes Int?
  quantity         Int      @default(1)

  filamentCost     Float?
  electricityCost  Float?
  printerCost      Float?
  totalCost        Float?

  externalJobId    String?
  apiDispatched    Boolean  @default(false)

  startedAt        DateTime?
  finishedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  order     ProductionOrder? @relation(fields: [orderId], references: [id])
  printer   Printer          @relation(fields: [printerId], references: [id])
  items     PrintJobItem[]
  materials PrintJobMaterial[]

  @@index([userId])
  @@index([orderId])
  @@index([printerId])
  @@index([status])
}

model ProfilePlate {
  id           String   @id @default(cuid())
  profileId    String
  plateNumber  Int      // ordem da placa (1, 2, 3…)
  name         String?  // ex: "Mesa 1 — Corpo", "Mesa 2 — Tampa"
  filePath     String?  // ficheiro .3mf específico desta placa (opcional)
  printTime    Int?     // minutos por corrida desta placa
  filamentUsed Float?   // gramas totais desta placa (soma de todas as cores)
  batchSize    Int      @default(1) // peças por corrida nesta placa

  profile   ComponentPrintProfile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  filaments ProfilePlateFilamentReq[]

  @@unique([profileId, plateNumber])
  @@index([profileId])
}

// 4. Requisitos de filamento por placa — separados dos ProfileFilamentReq do perfil:

model ProfilePlateFilamentReq {
  id         String  @id @default(cuid())
  plateId    String
  material   String
  colorHex   String?
  colorName  String?
  estimatedG Float

  plate ProfilePlate @relation(fields: [plateId], references: [id], onDelete: Cascade)

  @@index([plateId])
}


//////////////////////////////////////////////////////////
// PRINT JOB ITEM
//////////////////////////////////////////////////////////

model PrintJobItem {
  id          String  @id @default(cuid())
  jobId       String
  componentId String
  profileId   String?
  quantity    Int      @default(1)

  status      String   @default("pending")
  failedUnits Int      @default(0)
  costShare   Float?

  job       PrintJob               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  component Component              @relation(fields: [componentId], references: [id])
  profile   ComponentPrintProfile? @relation(fields: [profileId], references: [id])

  @@index([jobId])
  @@index([componentId])
}

//////////////////////////////////////////////////////////
// PRINT JOB MATERIAL
//////////////////////////////////////////////////////////

model PrintJobMaterial {
  id         String  @id @default(cuid())
  jobId      String
  slotId     String?
  spoolId    String?

  material   String
  colorHex   String?
  colorName  String?
  estimatedG Float
  actualG    Float?
  matchScore Int    @default(100)

  job   PrintJob           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  spool InventoryPurchase? @relation(fields: [spoolId], references: [id])

  @@index([jobId])
}

//////////////////////////////////////////////////////////
// GLOBAL FILAMENTS
//////////////////////////////////////////////////////////

model GlobalFilament {
  id          String   @id @default(cuid())
  brand       String
  material    String
  colorName   String
  colorCode   String?
  colorHex    String
  spoolWeight Float
  density     Float?
  createdAt   DateTime @default(now())

  @@index([brand])
  @@index([material])
  @@index([colorCode])
}

//////////////////////////////////////////////////////////
// SALES (Encomenda de Cliente / Sales Order)
//////////////////////////////////////////////////////////

model Sale {
  id           String   @id @default(cuid())
  userId       String
  productId    String
  customerName String?
  quantity     Int
  salePrice    Float
  notes        String?
  date         DateTime @default(now())
  customerId   String?

  // ← novo: estado da encomenda
  status       String   @default("pending")
  // "pending"          → aguarda produção (stock insuficiente, OP gerada)
  // "ready_to_ship"    → stock reservado, pronta a enviar
  // "shipped"          → enviada
  // "fulfilled"        → concluída
  // "cancelled"

  customer Customer?       @relation(fields: [customerId], references: [id])
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  product  Product         @relation(fields: [productId], references: [id])
  productionOrder ProductionOrder? // ← novo: OP vinculada (via salesOrderId na OP)

  @@index([userId])
  @@index([status])
}

//////////////////////////////////////////////////////////
// CUSTOMERS
//////////////////////////////////////////////////////////

model Customer {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String?
  phone     String?
  address   String?
  nif       String?
  notes     String?
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales Sale[]
}

//////////////////////////////////////////////////////////
// SETTINGS
//////////////////////////////////////////////////////////

model Settings {
  id     String @id @default(cuid())
  userId String
  key    String
  value  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

//////////////////////////////////////////////////////////
// PRINT PROFILES (legado)
//////////////////////////////////////////////////////////

model PrintProfile {
  id           String   @id @default(cuid())
  userId       String
  name         String
  filePath     String
  slicer       String?
  printTime    Int?
  filamentUsed Float?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
